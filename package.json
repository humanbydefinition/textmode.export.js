{
	"name": "textmode.export.js",
	"version": "1.2.1",
	"description": "Export plugin for textmode.js - Save your creations as images, GIFs, videos, SVG, and plain text.",
	"type": "module",
	"types": "./dist/types/index.d.ts",
	"main": "./dist/textmode.export.umd.js",
	"module": "./dist/textmode.export.esm.js",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/textmode.export.esm.js",
			"require": "./dist/textmode.export.umd.js"
		}
	},
	"sideEffects": [
		"./dist/textmode.export.esm.js",
		"./dist/textmode.export.umd.js"
	],
	"scripts": {
		"dev": "vite --port 5174 --host",
		"build": "vite build && tsc -p tsconfig.json",
		"check": "npm run format:check && npm run lint && npm run lint:md && npm run typecheck && npm run check:api-docs && npm run test && npm run build",
		"check:api-docs": "node ./scripts/check-public-api-docs.mjs",
		"dev:docs": "typedoc --watch",
		"build:docs": "typedoc",
		"preview": "vite preview",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest --passWithNoTests",
		"test:ui": "vitest --ui --passWithNoTests",
		"test:coverage": "vitest --coverage --passWithNoTests",
		"format": "prettier --write \"src/**/*.{ts,js}\" \"typedoc-plugins/**/*.js\" \"examples/**/*.{js,html,css}\" \"scripts/**/*.mjs\" \"*.{js,ts,json,md}\" \".markdownlint*.jsonc\" \".prettierrc\" \".releaserc.json\"",
		"format:check": "prettier --check \"src/**/*.{ts,js}\" \"typedoc-plugins/**/*.js\" \"examples/**/*.{js,html,css}\" \"scripts/**/*.mjs\" \"*.{js,ts,json,md}\" \".markdownlint*.jsonc\" \".prettierrc\" \".releaserc.json\"",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint:md": "markdownlint-cli2",
		"lint:md:fix": "markdownlint-cli2 --fix",
		"lint": "eslint src --config eslint.config.js",
		"prepare": "husky"
	},
	"peerDependencies": {
		"textmode.js": ">=0.10.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.3.1",
		"@commitlint/config-conventional": "^20.3.1",
		"@eslint/js": "^9.39.4",
		"@rollup/plugin-terser": "^0.4.4",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.2",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@types/node": "^24.5.2",
		"@vitest/ui": "^3.1.2",
		"eslint": "^9.39.2",
		"eslint-plugin-jsdoc": "^62.4.1",
		"globals": "^17.1.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.4.0",
		"markdownlint-cli2": "^0.20.0",
		"markdownlint-cli2-formatter-default": "^0.0.6",
		"prettier": "^3.7.4",
		"semantic-release": "^25.0.3",
		"terser": "^5.44.0",
		"textmode.js": "0.10.0",
		"typedoc": "^0.28.13",
		"typedoc-plugin-frontmatter": "^1.3.1",
		"typedoc-plugin-markdown": "^4.9.0",
		"typedoc-vitepress-theme": "^1.1.2",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.53.1",
		"vite": "^7.1.7",
		"vite-plugin-css-injected-by-js": "^3.5.2",
		"vitest": "^3.1.2"
	},
	"dependencies": {
		"gifenc": "^1.0.1",
		"webm-writer": "^1.0.0"
	},
	"keywords": [
		"textmode",
		"textmode.js",
		"ascii",
		"petscii",
		"export",
		"plugin",
		"gif",
		"video",
		"webm",
		"svg",
		"image",
		"png",
		"jpg",
		"webp",
		"creative-coding",
		"canvas"
	],
	"author": "humanbydefinition <hello@textmode.art> (https://code.textmode.art)",
	"license": "MIT",
	"homepage": "https://code.textmode.art",
	"lint-staged": {
		"**/*.{ts,js,mjs,json,jsonc,html,css,md}": "prettier --write"
	},
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/humanbydefinition/textmode.export.js.git"
	},
	"bugs": {
		"url": "https://github.com/humanbydefinition/textmode.export.js/issues"
	}
}
