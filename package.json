{
	"name": "textmode.export.js",
	"version": "1.5.2",
	"description": "Export plugin for textmode.js - Save your creations as images, GIFs, videos, SVG, JSON, and plain text.",
	"type": "module",
	"main": "./dist/textmode.export.umd.js",
	"module": "./dist/textmode.export.esm.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/textmode.export.esm.js",
			"require": "./dist/textmode.export.umd.js"
		}
	},
	"sideEffects": [
		"./dist/textmode.export.esm.js",
		"./dist/textmode.export.umd.js"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vite --port 5174 --host",
		"build:bundle": "vite build",
		"build:types": "tsc",
		"build": "npm run build:bundle && npm run build:types",
		"check": "npm run check:format && npm run lint && npm run lint:md && npm run check:types && npm run check:api-docs && npm run test && npm run build",
		"docs:links:add": "node ./scripts/add-api-doc-links.mjs",
		"check:api-docs": "node ./scripts/check-public-api-docs.mjs",
		"check:examples": "node ./scripts/check-examples.mjs",
		"dev:docs": "typedoc --watch",
		"build:docs": "typedoc",
		"preview": "vite preview",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest --passWithNoTests",
		"test:ui": "vitest --ui --passWithNoTests",
		"test:coverage": "vitest --coverage --passWithNoTests",
		"format": "prettier --write .",
		"check:format": "prettier --check .",
		"check:types": "tsc --noEmit",
		"lint:md": "markdownlint-cli2",
		"lint:md:fix": "markdownlint-cli2 --fix",
		"lint": "eslint src --config eslint.config.js",
		"prepare": "husky"
	},
	"peerDependencies": {
		"textmode.js": ">=0.13.0"
	},
	"dependencies": {
		"gifenc": "^1.0.1",
		"mediabunny": "^1.45.4"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^9.39.4",
		"@rollup/plugin-terser": "^0.4.4",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@types/node": "^24.0.13",
		"@vitest/ui": "^3.1.2",
		"eslint": "^9.39.2",
		"eslint-plugin-jsdoc": "^62.9.0",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.4.0",
		"markdownlint-cli2": "^0.22.1",
		"markdownlint-cli2-formatter-default": "^0.0.6",
		"prettier": "^3.8.3",
		"semantic-release": "^25.0.3",
		"terser": "^5.44.0",
		"textmode.js": "^0.16.0",
		"typedoc": "^0.28.19",
		"typedoc-plugin-frontmatter": "^1.3.1",
		"typedoc-plugin-markdown": "^4.11.0",
		"typedoc-vitepress-theme": "^1.1.2",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.59.0",
		"vite": "^6.3.4",
		"vite-plugin-css-injected-by-js": "^3.5.2",
		"vitest": "^3.1.2"
	},
	"keywords": [
		"textmode",
		"textmode.js",
		"ascii",
		"petscii",
		"export",
		"plugin",
		"gif",
		"video",
		"webm",
		"svg",
		"json",
		"image",
		"png",
		"jpg",
		"webp",
		"creative-coding",
		"canvas"
	],
	"author": "humanbydefinition <hello@textmode.art> (https://code.textmode.art)",
	"license": "MIT",
	"homepage": "https://code.textmode.art",
	"lint-staged": {
		"*": "prettier --ignore-unknown --write"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/humanbydefinition/textmode.export.js.git"
	},
	"bugs": {
		"url": "https://github.com/humanbydefinition/textmode.export.js/issues"
	}
}
